---
import Layout from '../layouts/Layout.astro';
import Dot from '../components/dot.jsx';
import Shuffle from '../components/shuffleText.jsx';
import Projects from '../components/Projects.astro';

---

<Layout>
  <div style={{ width: '100%', height: '100vh', position: 'relative', overflow: 'hidden', background: 'black' }}>
    {/* @ts-ignore */}
    <Dot
      dotRadius={3}
      dotSpacing={10}
      bulgeStrength={67}
      glowRadius={160}
      sparkle={false}
      waveAmplitude={0}
      cursorRadius={500}
      cursorForce={0.1}
      bulgeOnly
      gradientFrom="#A855F7"
      gradientTo="#B497CF"
      glowColor="#120F17"
      client:load
    />    
    <div class="absolute inset-x-0 bottom-0 h-48 bg-linear-to-t from-black to-transparent z-5 pointer-events-none"></div>

    <div class="absolute inset-0 flex flex-col items-center justify-center pointer-events-none px-4">
      <div class="pointer-events-auto">
                    {/* @ts-ignore */}

        <Shuffle
          text="Moksh Shah"
          className="font-pixel text-4xl md:text-6xl"
          shuffleDirection="right"
          duration={1.0}
          animationMode="random"
          maxDelay={1}
          shuffleTimes={1}
          ease="power3.out"
          stagger={0.03}
          threshold={0.1}
          triggerOnce={true}
          triggerOnHover
          respectReducedMotion={true}
          loop={false}
          loopDelay={0}
          colorFrom={'white'}
          colorTo={'white'}
          client:load
        />
      </div>
      <p class="text-white text-lg md:text-xl mt-4 font-bold tracking-wide text-center uppercase font-mono">
          Trying to build cool shit
      </p>
<a href="/terminal" class="pointer-events-auto">
<button
  class="group relative mt-8 inline-flex items-center justify-center px-3 py-3 font-pixel text-xs md:text-sm uppercase tracking-[0.2em] text-green-400 transition-all duration-500 ease-in-out"
>
  <span 
    class="absolute inset-0 border-2 border-green-500 bg-transparent
           group-hover:bg-green-400 group-hover:shadow-[0_0_30px_rgba(74,222,128,0.6)] 
           transition-all duration-500"
  ></span>

  <span class="absolute -top-3 -left-3 w-4 h-4 border-t-2 border-l-2 border-green-500 opacity-50 group-hover:opacity-100 group-hover:translate-x-1 group-hover:translate-y-1 transition-all duration-300"></span>
  <span class="absolute -bottom-3 -right-3 w-4 h-4 border-b-2 border-r-2 border-green-500 opacity-50 group-hover:opacity-100 group-hover:-translate-x-1 group-hover:-translate-y-1 transition-all duration-300"></span>

  <span class="relative z-10 flex items-center gap-3 group-hover:text-black transition-colors duration-500">
    <span class="opacity-0 -translate-x-2 group-hover:opacity-100 group-hover:translate-x-0 transition-all duration-300">
      &gt;
    </span>
    Terminal Website
    <svg 
      class="w-5 h-5 transform group-hover:translate-x-2 transition-transform duration-500" 
      fill="none" 
      stroke="currentColor" 
      viewBox="0 0 24 24"
    >
    </svg>
  </span>
</button>
</a>
    </div>
  </div>

  <Projects />

  <footer class="py-10 text-center text-gray-600 text-sm border-t border-white/5 bg-black">
    <p>&copy; 2026 Moksh Shah. All rights reserved.</p>
  </footer>
</Layout>
