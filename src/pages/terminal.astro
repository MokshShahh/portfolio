---
import Layout from '../layouts/Layout.astro';
import Dot from '../components/dot.jsx';
import Shuffle from '../components/shuffleText.jsx';
---

<Layout>
  <div style={{ width: '100%', height: '100vh', position: 'relative', overflow: 'hidden', background: 'black' }}>
    {/* @ts-ignore */}
    <Dot
      dotRadius={2}
      dotSpacing={10}
      bulgeStrength={67}
      glowRadius={160}
      sparkle={false}
      waveAmplitude={0}
      cursorRadius={500}
      cursorForce={0.1}
      bulgeOnly
      gradientFrom="#00CC32"
      gradientTo="#00CC32"
      glowColor="#120F17"
      client:load
    />    
        <div class="absolute inset-x-0 bottom-0 h-48 bg-linear-to-t from-black to-transparent z-5 pointer-events-none"></div>

    <div class="absolute inset-0 flex flex-col items-center justify-center pointer-events-none px-4">
      <div class="pointer-events-auto">
        {/* @ts-ignore */}
        <Shuffle
          text="Coming Soon"
          className="font-pixel text-4xl md:text-6xl text-white"
          shuffleDirection="right"
          duration={1.0}
          animationMode="random"
          maxDelay={1}
          shuffleTimes={1}
          ease="power3.out"
          stagger={0.03}
          threshold={0.1}
          triggerOnce={true}
          triggerOnHover
          respectReducedMotion={true}
          loop={false}
          loopDelay={0}
          colorFrom={'white'}
          colorTo={'white'}
          client:load
        />
      </div>
      <p class="text-white/80 text-sm md:text-base mt-6 font-mono tracking-widest text-center uppercase">
          The terminal experience is under development
      </p>
      
      <div class="mt-12 flex gap-4 pointer-events-auto">
        <a href="/" class="group relative inline-flex items-center justify-center px-6 py-3 font-pixel text-xs md:text-sm uppercase tracking-[0.2em] text-green-400 transition-all duration-500 ease-in-out">
          <span class="absolute inset-0 border-2 border-green-500 bg-transparent group-hover:bg-green-400 group-hover:shadow-[0_0_30px_rgba(74,222,128,0.6)] transition-all duration-500"></span>
          
          <span class="absolute -top-3 -left-3 w-4 h-4 border-t-2 border-l-2 border-green-500 opacity-50 group-hover:opacity-100 group-hover:translate-x-1 group-hover:translate-y-1 transition-all duration-300"></span>
          <span class="absolute -bottom-3 -right-3 w-4 h-4 border-b-2 border-r-2 border-green-500 opacity-50 group-hover:opacity-100 group-hover:-translate-x-1 group-hover:-translate-y-1 transition-all duration-300"></span>

          <span class="relative z-10 flex items-center gap-3 group-hover:text-black transition-colors duration-500">
            <span class="opacity-0 -translate-x-2 group-hover:opacity-100 group-hover:translate-x-0 transition-all duration-300">
              &lt;
            </span>
            Return Home
          </span>
        </a>
      </div>
    </div>
  </div>
</Layout>
